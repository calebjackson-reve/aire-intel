generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id              String    @id @default(cuid())
  // Identity
  name            String
  firstName       String?
  lastName        String?
  phone           String?
  email           String?
  // Pipeline
  stage           String    @default("new_lead")
  type            String    @default("buyer")   // buyer | seller | both | investor | referral
  pricePoint      Float?
  priceMin        Float?
  priceMax        Float?
  // Property interest
  address         String?
  beds            Int?
  baths           Float?
  sqftMin         Int?
  sqftMax         Int?
  areas           String?   // comma-separated neighborhoods/parishes
  // Context
  motivation      String?
  timeline        String?   // immediate | 1-3mo | 3-6mo | 6-12mo | 12mo+
  preApproved     Boolean   @default(false)
  preApprovalAmt  Float?
  referredBy      String?
  source          String?
  tags            String?   // comma-separated
  birthday        DateTime?
  anniversary     DateTime?
  // Follow-up
  lastContactDate DateTime?
  nextActionDate  DateTime?
  nextActionNote  String?
  assignedTo      String?
  // Touch cadence — drives the unified Touch Tracker
  preferredPlatform String?  // imessage | facebook | instagram | snapchat | linkedin — channel this person actually responds on
  touchCadenceDays  Int?     // desired days between touches; null = use tier default
  doNotContact      Boolean  @default(false)
  // Contract dates — populated when stage transitions to under_contract.
  // contractDate = date the offer was accepted / contract executed.
  // closingDate  = scheduled closing date. Used to auto-generate milestone tasks
  //                (inspection +7d, appraisal +14d, final walk -2d, closing).
  contractDate    DateTime?
  closingDate     DateTime?
  // Lofty import fields
  loftyId         String?   @unique
  // Social handles (manual entry, friend-list match, or AI suggestion)
  instagramHandle String?
  facebookUrl     String?   // full URL or "facebook.com/username" — supports vanity + numeric profiles
  facebookName    String?   // display name as it appeared in friends export (helps re-match)
  linkedinUrl     String?
  tiktokHandle    String?
  twitterHandle   String?
  photoUrl        String?   // cached profile picture URL
  // Meta
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  timeline_logs    ContactLog[]
  posts            GeneratedPost[]
  tasks            Task[]
  smartPlans       SmartPlanEnrollment[]
  buyerSearches    BuyerSearch[]
  loops            DotloopLoop[]
  linkedInOutreach LinkedInOutreach[]
  messageDrafts    MessageDraft[]
  propertyIntel    PropertyIntel?
  actionQueue      ActionQueue[]
  memoryIndex      MemoryIndex[]
  iMessageThreads  IMessageThread[]
}

// Homeowner / property attributes imported from a PropStream CSV export (the only
// in-bounds PropStream path — see docs/intent-data-legal.md). One row per lead;
// used ONLY as a marketing-prioritization input for the sell-intent score, never
// for any FCRA credit/eligibility decision.
model PropertyIntel {
  id             String    @id @default(cuid())
  leadId         String    @unique
  // Core sell-intent attributes
  equityPct      Float? // estimated equity as % of value (0..100)
  estimatedValue Float?
  ownershipYears Float? // tenure since last sale
  lastSaleDate   DateTime?
  ownerOccupied  Boolean? // null = unknown
  absentee       Boolean? // owner mailing addr ≠ property addr
  preForeclosure Boolean?
  propertyType   String?
  siteAddress    String?
  // Provenance
  source     String   @default("propstream")
  raw        String? // original CSV row as JSON, for audit
  importedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

/**
 * A Dotloop transaction "loop" mirrored into AIRE.
 *
 * Most transactional fact lives in Dotloop (signatures, docs, deadlines).
 * This local copy is a lightweight pointer so the AIRE contact profile can
 * show loop status at a glance and link out to Dotloop for the full file.
 * Synced via /api/dotloop/sync — idempotent by dotloopId.
 */
model DotloopLoop {
  id            String    @id @default(cuid())
  dotloopId     String    @unique // Dotloop's numeric loop ID
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  name          String
  status        String    // PRE_OFFER | UNDER_CONTRACT | SOLD | LEASED | etc.
  loopType      String?   // PURCHASE | LISTING_FOR_LEASE | LISTING_FOR_SALE | etc.
  streetAddress String?
  city          String?
  state         String?
  zipCode       String?
  // Money + dates pulled into local copy so dashboard widgets don't re-fetch every render
  acceptanceDate DateTime?
  closingDate   DateTime?
  expectedClosingDate DateTime?
  contractDate  DateTime?
  salePrice     Float?
  commission    Float?
  // Participant snapshot — JSON because shape varies (buyer agent, seller agent, lender, etc.)
  participantsJson String? // JSON array of { name, role, email, phone }
  // Cached counts for fast UI rendering
  signedDocsCount   Int @default(0)
  pendingDocsCount  Int @default(0)
  // Sync bookkeeping
  lastSyncedAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ContactLog {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  method    String   // text | call | email | showing | meeting | note | ai_message | dm
  platform  String?  // imessage | facebook | instagram | snapchat | linkedin | email | phone | inperson
  note      String?
  direction String   @default("outbound") // inbound | outbound
  externalId String? @unique // dedupe key for auto-ingested messages (e.g. imessage GUID)
  touchedAt DateTime @default(now()) // when the touch actually happened (differs from createdAt on backfills)
  createdAt DateTime @default(now())

  @@index([leadId, platform])
}

model Task {
  id          String    @id @default(cuid())
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("normal") // urgent | high | normal | low
  done        Boolean   @default(false)
  doneAt      DateTime?
  assignedTo  String?
  createdAt   DateTime  @default(now())
}

model SmartPlan {
  id          String   @id @default(cuid())
  name        String
  description String?
  triggerType String   // new_lead | stage_change | no_contact | manual
  steps       String   // JSON array of steps
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  enrollments SmartPlanEnrollment[]
}

model SmartPlanEnrollment {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  planId      String
  plan        SmartPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  currentStep Int       @default(0)
  active      Boolean   @default(true)
  startedAt   DateTime  @default(now())
  nextStepAt  DateTime?
}

model GeneratedPost {
  id            String   @id @default(cuid())
  leadId        String?
  lead          Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  postType      String
  address       String?
  price         Float?
  rawNotes      String?
  caption       String?
  slideCopy     String?
  motionSpec    String?
  platform      String   @default("instagram")
  approved      Boolean  @default(false)
  // Quality + learning
  qualityScore  Float?
  qualityFlags  String?  // JSON
  userFeedback  String?  // approved | rejected | edited
  feedbackNote  String?
  promptVersion Int?     // which prompt evolution version generated this
  attempts      Int?     @default(1)  // gate retry count (1 = passed first try)
  createdAt     DateTime @default(now())
}

model DailyBrief {
  id               String    @id @default(cuid())
  date             String    @unique  // "2026-06-09" — one per day
  nonNegotiables   Json?
  goingCold        Json?
  owePeople        Json?
  contentQueued    Json?
  marketMovement   Json?
  smsSummary       String?
  smsDeliveredAt   DateTime?
  emailDeliveredAt DateTime?
  pushDeliveredAt  DateTime?
  assembledAt      DateTime  @default(now())
  agentRunId       String?
}

model ActionQueue {
  id               String    @id @default(cuid())
  type             String    // draft_message | post_content | create_lofty_task | send_client_email | follow_up_text
  payload          Json
  status           String    @default("pending")
  agentType        String
  leadId           String?
  lead             Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  requiresApproval Boolean   @default(true)
  priority         Int       @default(5)
  briefDate        String?
  approvedAt       DateTime?
  executedAt       DateTime?
  skippedAt        DateTime?
  failedAt         DateTime?
  failReason       String?
  scheduledFor     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([briefDate])
  @@index([leadId])
}

model AgentRun {
  id             String    @id @default(cuid())
  agentType      String
  status         String    // running | completed | failed | partial
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  itemsProcessed Int       @default(0)
  actionsQueued  Int       @default(0)
  errorLog       Json?
  durationMs     Int?

  @@index([agentType, startedAt])
}

model ZillowHotListing {
  id           String   @id @default(cuid())
  zpid         String   @unique
  address      String
  city         String
  state        String
  zip          String
  price        Float?
  beds         Int?
  baths        Float?
  sqft         Int?
  viewCount    Int?
  saveCount    Int?
  daysOnMarket Int?
  listingUrl   String
  photoUrl     String?
  fetchedAt    DateTime @default(now())
  usedInPostId String?
}

model BuyerSearch {
  id          String   @id @default(cuid())
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  name        String   // "The Joneses – Gardere $350K"
  priceMin    Float?
  priceMax    Float?
  bedsMin     Int?
  bathsMin    Float?
  sqftMin     Int?
  areas       String?  // comma-separated zip codes / neighborhoods
  propertyTypes String? // comma-separated: residential,condo,land
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  alerts      ListingAlert[]
}

model ListingAlert {
  id            String      @id @default(cuid())
  buyerSearchId String
  buyerSearch   BuyerSearch @relation(fields: [buyerSearchId], references: [id], onDelete: Cascade)
  mlsNumber     String
  address       String
  price         Float
  beds          Int?
  baths         Float?
  sqft          Int?
  photoUrl      String?
  listingUrl    String?
  listedAt      DateTime    @default(now())
  seen          Boolean     @default(false)
  emailed       Boolean     @default(false)
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // listing_match | lead_assigned | task_due | sync_complete | social_post
  title     String
  body      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SocialConnection {
  id           String   @id @default(cuid())
  platform     String   @unique // facebook | instagram
  accessToken  String
  pageId       String?
  pageName     String?
  expiresAt    DateTime?
  connectedAt  DateTime @default(now())
}

// Karpathy-style error memory: every failure is logged, attributed, and tracked to resolution
model ErrorLog {
  id         String   @id @default(cuid())
  type       String   // api_failure | validation | sync | ui | ai | lofty | paragon | meta
  source     String   // which route/component/function
  message    String
  context    String?  // JSON: what was happening when it failed
  stack      String?
  attempts   Int      @default(1)
  resolved   Boolean  @default(false)
  resolution String?  // what fixed it
  resolvedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ScheduledPost {
  id             String   @id @default(cuid())
  platform       String   // facebook | instagram | both
  caption        String
  slidesCopy     String?  // JSON array of slide objects
  motionSpec     String?
  imageUrl       String?
  scheduledFor   DateTime?
  publishedAt    DateTime?
  status         String   @default("draft") // draft | scheduled | published | failed
  postId         String?  // platform post ID after publish
  leadId         String?
  postType       String?  // just_listed | just_sold | market_update | etc
  // Quality + learning
  qualityScore   Float?   // 0-100 scored by quality gate
  qualityFlags   String?  // JSON array of flag strings
  userFeedback   String?  // approved | rejected | edited
  feedbackNote   String?  // optional note on why
  // Performance (filled when Meta reports back)
  reach          Int?
  impressions    Int?
  engagement     Int?
  engagementRate Float?
  createdAt      DateTime @default(now())
}

// Learned content preferences — extracted from approved posts over time
model ContentPreference {
  id           String   @id @default(cuid())
  patternType  String   // hook_style | cta_format | hashtag | tone | structure
  value        String   // the actual pattern or phrase
  approvals    Int      @default(0)
  rejections   Int      @default(0)
  approvalRate Float    @default(0)
  lastSeen     DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([patternType, value])
}

model Deal {
  id            String    @id @default(cuid())
  leadId        String?
  // Property
  address       String
  city          String?
  // Money
  salePrice     Float
  commission    Float     // dollar amount, not percent
  commissionPct Float?    // percentage rate at closing (e.g. 2.5)
  // Side + status
  side          String    // buyer | seller | both
  status        String    @default("closed") // pending | closed | fell_through
  // Dates
  contractDate  DateTime?
  closingDate   DateTime
  // Attribution
  source        String?   // manual | lofty | paragon
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/**
 * A dead-lead revival experiment cohort.
 *
 * Proof framework: a cohort is a frozen snapshot of dead leads (90+ days old,
 * stage new_lead/active, zero inbound ContactLog ever) split into a treatment
 * arm (gets voice-matched revival drafts) and a holdout arm (~20%, no outreach).
 * baselineRate is captured at creation so every later result is measured against
 * the historical revival rate. Outcomes are read live by joining leadIds back to
 * ContactLog (inbound replies) and Lead.stage advancement.
 */
model RevivalCohort {
  id           String   @id @default(cuid())
  name         String
  createdAt    DateTime @default(now())
  leadIds      String   // JSON array of treatment-arm lead ids
  holdoutIds   String   @default("[]") // JSON array of holdout-arm lead ids (no outreach)
  baselineRate Float?   // historical revival rate captured at cohort creation
  notes        String?
}

// A communication-agent draft awaiting Caleb's approval. Drafts are NEVER auto-sent
// (TCPA-safe). Approving one fires the existing SMS/email path, writes a ContactLog,
// and — if linked to a cohort — counts toward provable revival outcomes.
model MessageDraft {
  id        String    @id @default(cuid())
  leadId    String
  channel   String // "text" | "email"
  subject   String? // email only
  body      String
  status    String    @default("pending") // pending | approved | sent | dismissed
  source    String // "revival" | "followup" | "manual"
  cohortId  String? // links to RevivalCohort for proof
  createdAt DateTime  @default(now())
  sentAt    DateTime?

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([leadId])
  @@index([cohortId])
}

model Goal {
  id          String   @id @default(cuid())
  metric      String   @unique // gci_annual | volume_annual | units_annual | leads_monthly
  targetValue Float
  period      String   // year | quarter | month
  year        Int
  notes       String?
  updatedAt   DateTime @updatedAt
}

/**
 * LinkedIn manual-assist outreach queue.
 *
 * Caleb generates a message in AIRE, copies it with one click, pastes it
 * manually on LinkedIn. No LinkedIn OAuth / API — zero ToS risk.
 *
 * Status flow: message_generated → copied → sent
 */
model LinkedInOutreach {
  id          String    @id @default(cuid())
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  message     String
  status      String    @default("message_generated") // message_generated | copied | sent
  generatedAt DateTime  @default(now())
  copiedAt    DateTime?
  sentAt      DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================================
// CONTENT-FIRST CORE (rebuild) — additive, see plan keen-watching-metcalfe
// ============================================================

/// The creative unit. Evolves GeneratedPost; one row per post/carousel/reel.
model ContentProject {
  id              String   @id @default(cuid())
  type            String   // just_listed | just_sold | client_story | market_update | educational | reel
  status          String   @default("idea") // idea | drafting | ready | scheduled | published | archived
  brief           String?  // raw notes the agent enters
  captionDraft    String?  // AI-generated caption (for the learning loop)
  captionFinal    String?  // what was actually published (compare vs draft)
  slideSpec       Json?    // structured per-slide JSON the renderer consumes
  motionSpec      String?
  hashtags        Json?
  clientRefId     String?
  clientRef       ClientRef? @relation(fields: [clientRefId], references: [id], onDelete: SetNull)
  mlsId           String?  // AIRE: loop:listing-content-production — dedup guard per listing
  listingAddress  String?
  price           Float?
  platform        String?  // comma-separated: instagram,facebook
  scheduledFor    DateTime?
  publishedAt     DateTime?
  externalPostIds Json?    // { instagram: "...", facebook: "..." }
  trendSignalId   String?
  trendSignal     TrendSignal? @relation(fields: [trendSignalId], references: [id], onDelete: SetNull)
  referenceRecipeId String?
  referenceRecipe   VideoRecipe? @relation(fields: [referenceRecipeId], references: [id], onDelete: SetNull)
  media           MediaAsset[]
  renderJobs      RenderJob[]
  performance     ContentPerformance[]
  importedPosts   ImportedPost[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Source photos + rendered slides/stories/reels. Public HTTPS URLs (Blob/S3).
model MediaAsset {
  id               String   @id @default(cuid())
  contentProjectId String?
  contentProject   ContentProject? @relation(fields: [contentProjectId], references: [id], onDelete: Cascade)
  kind             String   // source_photo | carousel_slide | story | reel
  url              String
  blobPathname     String?  // for deletion from blob store
  width            Int?
  height           Int?
  durationMs       Int?     // reels only
  slideIndex       Int?     // ordering within a carousel
  layoutVariant    String?  // which template produced it
  mimeType         String
  bytes            Int?
  createdAt        DateTime @default(now())
}

/// Async render state for heavy outputs (reels).
model RenderJob {
  id               String   @id @default(cuid())
  contentProjectId String
  contentProject   ContentProject @relation(fields: [contentProjectId], references: [id], onDelete: Cascade)
  assetType        String   // carousel | story | reel
  status           String   @default("queued") // queued | rendering | done | failed
  renderId         String?  // AIRE: loop:render-job-completion — external job ID for polling/webhook
  outputUrl        String?  // AIRE: loop:render-job-completion — URL of completed render output
  error            String?
  resultAssetId    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// Learning-loop sink: Meta insights snapshotted per published post, joined by externalPostId.
model ContentPerformance {
  id               String   @id @default(cuid())
  contentProjectId String?
  contentProject   ContentProject? @relation(fields: [contentProjectId], references: [id], onDelete: SetNull)
  externalPostId   String
  platform         String
  publishedAt      DateTime?
  reach            Int?
  impressions      Int?
  engagement       Int?
  saves            Int?
  shares           Int?
  comments         Int?
  clicks           Int?
  engagementRate   Float?
  fetchedAt        DateTime @default(now())

  @@unique([externalPostId, platform])
}

/// Trend research storage. Trends decay (expiresAt).
model TrendSignal {
  id        String   @id @default(cuid())
  source    String   // manual | meta_audit | web_research | skill
  topic     String
  hook      String?
  detail    String?
  score     Float?
  status    String   @default("new") // new | queued | used | dismissed
  expiresAt DateTime?
  projects  ContentProject[]
  createdAt DateTime @default(now())
}

/// Reusable layout/motion presets for the visual engine.
model BrandTemplate {
  id         String   @id @default(cuid())
  name       String
  type       String
  configJson Json?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

/// Thin, read-only mirror of Lofty leads — used only to tag clients in content.
model ClientRef {
  id                String   @id @default(cuid())
  loftyId           String?  @unique
  name              String
  type              String?
  stage             String?
  lastClosedAddress String?
  instagramHandle   String?
  tags              String?
  syncedAt          DateTime @default(now())
  projects          ContentProject[]
}

/**
 * Zillow market intelligence cache.
 *
 * Scraped from Zillow's internal search API for private market research by a
 * licensed REALTOR®. NOT for republication. Cached 24h to minimize requests.
 * Covers Baton Rouge, Zachary, St. Francisville markets.
 *
 * status: "for_sale" | "recently_sold" | "for_rent"
 * priceHistory: JSON array of { date, price, event } from Zillow
 */
model ZillowListing {
  id            String   @id @default(cuid())
  zpid          String   @unique          // Zillow property ID
  address       String
  city          String
  state         String   @default("LA")
  zip           String
  price         Float?
  beds          Int?
  baths         Float?
  sqft          Int?
  lotSqft       Int?
  yearBuilt     Int?
  propertyType  String?                   // SingleFamily | Condo | Townhouse | Land
  daysOnMarket  Int?
  zestimate     Float?
  rentZestimate Float?
  status        String                    // for_sale | recently_sold | for_rent
  soldPrice     Float?                    // populated for recently_sold
  soldDate      DateTime?
  listingUrl    String
  photoUrl      String?
  priceHistory  Json?                     // [{ date, price, event }]
  hoaFee        Float?
  taxAnnual     Float?
  description   String?
  scrapedAt     DateTime @default(now())
  source        String   @default("zillow_internal")

  @@index([city, status])
  @@index([status, scrapedAt])
  @@index([zip, status])
}

/// Persistent conversation threads for AIRE Jarvis chat
model ChatThread {
  id           String        @id @default(cuid())
  title        String?
  messageCount Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]
}

/// Materialized search index for Jarvis memory — rebuilt by background cron.
/// Covers Lead, ContactLog, and ChatMessage rows in a single FTS-ready table.
/// The search_vector tsvector column and GIN index are added via manual SQL after migration
/// (see prisma/migrations/manual_gin_index.sql).
model MemoryIndex {
  id         String   @id @default(cuid())
  /// Source table identifier
  sourceType String   // lead | contact_log | chat_message
  sourceId   String
  /// Lead this memory is about (nullable for chat messages without lead context)
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  /// The raw text excerpt displayed in results
  excerpt    String
  /// Full concatenated text used to build the tsvector — stored for re-indexing
  rawText    String
  /// Timestamp of the original source row (used for recency sorting)
  sourceAt   DateTime
  /// When this index row was last rebuilt
  indexedAt  DateTime @default(now())

  @@unique([sourceType, sourceId])
  @@index([leadId])
  @@index([sourceAt])
}

/// Raw imported contact from Facebook friends export, Instagram export, or vCard.
/// Staging table — matched records get merged into Lead; unmatched remain here
/// so they're visible on the /people page and can be merged later.
model SocialPerson {
  id              String   @id @default(cuid())
  source          String   // facebook | instagram | contacts
  externalId      String?  // FB friend URL, IG handle, vCard UID
  name            String
  firstName       String?
  lastName        String?
  email           String?
  phone           String?
  instagramHandle String?
  facebookUrl     String?
  facebookName    String?
  avatarUrl       String?
  matchedLeadId   String?  // set once confirmed-matched to a Lead
  matchScore      Float?   // 0-1, from the dedup run that found this match
  matchReason     String?
  importedAt      DateTime @default(now())

  @@unique([source, externalId])
  @@index([matchedLeadId])
  @@index([name])
}

/// Historical post imported from a Meta data export (Instagram or Facebook).
model SocialExport {
  id           String             @id @default(cuid())
  platform     String             // instagram | facebook
  exportedAt   DateTime
  importedAt   DateTime           @default(now())
  periodStart  DateTime?
  periodEnd    DateTime?
  status       String             @default("pending") // pending | processing | complete | failed
  postCount    Int                @default(0)
  reelCount    Int                @default(0)
  insightCount Int                @default(0)
  posts        ImportedPost[]
  snapshots    AudienceSnapshot[]
}

model ImportedPost {
  id               String          @id @default(cuid())
  exportId         String
  export           SocialExport    @relation(fields: [exportId], references: [id])
  platform         String
  caption          String?
  publishedAt      DateTime
  postType         String?
  isReel           Boolean         @default(false)
  imageCount       Int             @default(0)
  hashtags         Json?
  hashtagCount     Int             @default(0)
  taggedUsers      Json?
  hasLocation      Boolean         @default(false)
  reach            Int?
  impressions      Int?
  likes            Int?
  comments         Int?
  shares           Int?
  saves            Int?
  profileVisits    Int?
  follows          Int?
  engagementRate   Float?
  hookStyle        String?
  captionLength    Int?
  ctaType          String?
  sentimentScore   Float?
  contentProjectId String?
  contentProject   ContentProject? @relation(fields: [contentProjectId], references: [id])
  createdAt        DateTime        @default(now())

  @@unique([platform, publishedAt, caption])
  @@index([platform, postType])
  @@index([publishedAt])
}

model AudienceSnapshot {
  id                String       @id @default(cuid())
  exportId          String
  export            SocialExport @relation(fields: [exportId], references: [id])
  snapshotDate      DateTime
  platform          String
  totalFollowers    Int?
  followerDelta     Float?
  accountsReached   Int?
  reachDelta        Float?
  nonFollowerPct    Float?
  totalInteractions Int?
  interactionDelta  Float?
  reelsInteractions Int?
  postInteractions  Int?
  storyInteractions Int?
  topCities         Json?
  ageBreakdown      Json?
  genderBreakdown   Json?
  peakDay           String?
  peakHour          Int?
  createdAt         DateTime     @default(now())
}

model PredictionAccuracy {
  id                  String    @id @default(cuid())
  contentProjectId    String?
  postType            String?
  isReel              Boolean   @default(false)
  platform            String
  predictedReach      Int
  actualReach         Int?
  predictedEngagement Int
  actualEngagement    Int?
  reachDelta          Float?
  engagementDelta     Float?
  signalsUsed         Json?
  fetchedAt           DateTime?
  publishedAt         DateTime
  createdAt           DateTime  @default(now())

  @@index([platform, postType])
}

/// Torn-down video analysis recipe — powers the self-improving Video Brain.
model VideoRecipe {
  id           String   @id @default(cuid())
  url          String?                          // original URL (Instagram/TikTok/direct)
  sourceType   String                           // instagram | tiktok | upload | study | queued
  recipe       Json                             // EditRecipe JSON from Python analyzer
  thumbnailUrl String?
  notes        String?
  hookPatterns Json?                            // [{ archetype, formula, example }]
  approvalRate Float?                           // set by weekly agent from top-performing reels
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  projects     ContentProject[]
}

/// Individual messages within a ChatThread
model ChatMessage {
  id            String     @id @default(cuid())
  threadId      String
  role          String     // user | assistant
  content       String
  toolCallsJson String?    // serialized tool use blocks
  createdAt     DateTime   @default(now())
  thread        ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

// ── iMessage Integration ──────────────────────────────────────────────────────

/// One thread per phone number — synced from ~/Library/Messages/chat.db via bridge
model IMessageThread {
  id          String            @id @default(cuid())
  phone       String            @unique  // E.164 normalized e.g. +12255551234
  displayName String?           // from Contacts app or first message sender
  leadId      String?           // matched AIRE lead (null if not yet matched)
  lead        Lead?             @relation(fields: [leadId], references: [id])
  lastBody    String?           // snippet of the most recent message
  lastAt      DateTime?         // timestamp of most recent message
  needsReply  Boolean           @default(false) // last message was inbound, no outbound reply since
  messages    IMessageMessage[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([lastAt])
  @@index([needsReply])
}

/// Individual iMessages within a thread
model IMessageMessage {
  id        String         @id @default(cuid())
  threadId  String
  thread    IMessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  guid      String         @unique  // Apple's GUID — dedup key
  body      String
  direction String         // inbound | outbound
  sentAt    DateTime
  createdAt DateTime       @default(now())

  @@index([threadId, sentAt])
}
